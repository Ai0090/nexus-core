## TET-Core local development environment variables (example)
## Copy to `.env` and fill with real values. Never commit `.env`.

# Core server
PORT=5010
TET_DB_DIR=tet.db_5010

# Enable/disable features
TET_ENABLE_P2P=1
TET_DISABLE_RATE_LIMIT=1

# Admin
TET_ADMIN_API_KEY=changeme-dev-admin-key

# Wallet / identity (dev only)
TET_WALLET_ID=local-wallet

# P2P bootstrap (optional)
# Example: /ip4/127.0.0.1/tcp/4001/p2p/12D3KooW...
# TET_BOOTSTRAP_PEER=

# ZK / RISC0 (CI can skip guest build with this)
# RISC0_SKIP_BUILD=1
## TET-Core — GCP production template
##
## CRITICAL:
## - Set a strong DB key. Production mode will refuse to boot without it.
## - Never commit real mnemonics or keys.

# Bind on all interfaces (Docker/GCP)
TET_REST_BIND=0.0.0.0:5010

# Production mode (enforces encryption requirements)
TET_PROD=true

# Ledger database directory (sled). In docker-compose this maps to ./tet_data on host.
TET_DB_DIR=/app/tet.db

# REQUIRED: 32-byte base64 key for at-rest encryption
TET_DB_KEY_B64="YOUR_32_BYTE_BASE64_KEY_HERE"

# Required for genesis founder premine / founder-only operations
TET_FOUNDER_MNEMONIC="your twelve words here..."

# Optional: enable cross-origin only if you are hosting the UI elsewhere.
# If UI is served by the same core node, you typically do NOT need CORS.
TET_CORS_ORIGINS="http://your-gcp-ip:5010"

